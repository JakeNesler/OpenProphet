# Alpaca API Configuration
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_PUBLIC_KEY=your_alpaca_public_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# AI provider for news cleaning (optional)
# AI_PROVIDER=claude   # "claude" or "xai" — auto-detected from whichever key is set if omitted
CLAUDE_API_KEY=your_claude_api_key
XAI_API_KEY=your_xai_api_key

# Email for PennyProphet
OPERATOR_EMAIL=your@email.com

# Financial Modeling Prep API key (required for PennyProphet universe screening)
FMP_API_KEY=your_fmp_api_key

# Reddit OAuth (script app) for PennyProphet social signals.
# Create a "script" app at https://www.reddit.com/prefs/apps using a dedicated bot account.
# When all four are set, social_signal_service polls oauth.reddit.com with bearer-token
# auth (~60 req/min). When any is missing, Reddit polls are skipped (StockTwits still runs).
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USERNAME=your_bot_account_username
# REDDIT_PASSWORD=your_bot_account_password
# REDDIT_USER_AGENT=                       # optional override; defaults to "go:prophet-penny-bot:1.0 (by /u/<username>)"

# Agent Dashboard Configuration (optional)
AGENT_PORT=3737                        # Dashboard port (default: 3737)
AGENT_AUTH_TOKEN=                       # Set a token to require auth on all API routes
TRADING_BOT_PORT=4534                   # Go backend port (default: 4534)
TRADING_BOT_URL=http://localhost:4534   # Go backend URL (default: auto from port)

# Second Alpaca account (optional — auto-creates a second sandbox on startup if not already present)
# ALPACA_NAME_2=Account 2
# ALPACA_PUBLIC_KEY_2=your_second_public_key
# ALPACA_SECRET_KEY_2=your_second_secret_key
# ALPACA_ENDPOINT_2=https://paper-api.alpaca.markets
# ALPACA_PAPER_2=true
