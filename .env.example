# Alpaca API Configuration
ALPACA_ENDPOINT=https://paper-api.alpaca.markets
ALPACA_PUBLIC_KEY=your_alpaca_public_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Gemini API (optional - for AI news cleaning)
GEMINI_API_KEY=your_gemini_api_key

# Agent Dashboard Configuration (optional)
AGENT_PORT=3737                        # Dashboard port (default: 3737)
AGENT_AUTH_TOKEN=                       # Set a token to require auth on the dashboard API routes
TRADING_BOT_PORT=4534                   # Go backend port (default: 4534)
TRADING_BOT_URL=http://127.0.0.1:4534   # Go backend URL (default: auto from port)

# Trading backend security (optional)
SERVER_HOST=127.0.0.1                   # Go backend bind address (default: 127.0.0.1 loopback only)
TRADING_BOT_TOKEN=                      # Bearer token for the Go trading API. Leave blank and the
                                        # dashboard mints an ephemeral one at startup; set a stable
                                        # value only if you run the Go backend as a separate process.
CORS_ALLOWED_ORIGINS=                   # Comma-separated allowlist; blank = reflect localhost only
